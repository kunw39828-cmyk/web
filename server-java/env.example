# 复制为 server-java/.env 后按需填写（勿提交 .env）

# 微信开放平台「网站应用」扫码登录 https://open.weixin.qq.com/
# 授权回调 URL 须为：{APP_PUBLIC_BASE_URL}/api/auth/wechat/callback
WECHAT_OPEN_ENABLED=false
WECHAT_OPEN_APP_ID=
WECHAT_OPEN_APP_SECRET=

# 前端与后端对外地址（微信回调、OAuth 完成后跳转）
FRONTEND_BASE_URL=http://localhost:5173
APP_PUBLIC_BASE_URL=http://localhost:3000

# Web Push（浏览器推送）：在项目根执行 npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost
