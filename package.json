{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:server:auto\" \"npm run dev:web:auto\"",
    "dev:web": "vite --port 5173",
    "dev:web:auto": "kill-port 5173 && npm run dev:web",
    "dev:server": "node server/index.js",
    "dev:server:auto": "kill-port 3001 && node server/index.js",
    "dev:server:java": "mvn -f server-java/pom.xml spring-boot:run",
    "build": "vue-tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "pinia": "^3.0.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@vitejs/plugin-vue": "^4.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^13.24.0",
    "kill-port": "^2.0.1",
    "typescript": "~5.4.5",
    "typescript-eslint": "^8.59.0",
    "vite": "^4.5.14",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^1.8.27"
  }
}
